    <object Name="Ursa_NeverhomeDoor" Inherits="Door">
        <part Name="Render" DisplayName="pneumatic door" ColorString="&amp;c" TileColor="&amp;c" DetailColor="Y" Tile="Objects/Ursa_NeverhomeDoor.png" />
